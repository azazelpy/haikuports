LICENSE="Apache v2"
REVISION="4"
SOURCE_URI="https://github.com/msgpack/msgpack-python/archive/v$portVersion.tar.gz"
CHECKSUM_SHA256="576a1835a8b48d5861c883a6e10fd374065c6ae56287b221d1a4791e9529c71c"
SOURCE_DIR="msgpack-python-$portVersion"

ARCHITECTURES="any"

